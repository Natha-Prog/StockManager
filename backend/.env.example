PORT=5000
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# Dev local : SQLite (laisser DB_PATH, ne pas définir DATABASE_URL)
DB_PATH=./stock.db

# Production (Render) — Supabase Postgres (désactive SQLite)
# Recommandé pour Express : session-mode pooler (port 5432)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-....pooler.supabase.com:5432/postgres
#
# Alternative : transaction-mode pooler (port 6543, IPv4-only)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres?pgbouncer=true

ADMIN_EMAIL=admin@stock.local
ADMIN_PASSWORD=admin123
